generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  hashedPassword String?
  phone          String?
  role           Role           @default(OWNER)
  referralCode   String?        @unique
  referredById   String?
  onboardingCompleted Boolean  @default(false)
  telegramForumTopicId Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  establishments Establishment[]
  subscriptions  Subscription[]
  templates      Template[]
  fileAssets     FileAsset[]
  businessCards     BusinessCard[]
  wifiConfigs       WifiConfig[]
  messengerContacts MessengerContact[]
  qrcodes           QRCode[]
  activationBatches ActivationBatch[]
  supportTickets    SupportTicket[]
  establishmentMemberships EstablishmentMember[]
  sentInvites       EstablishmentMember[] @relation("SentInvites")

  referredBy       User?              @relation("PartnerReferral", fields: [referredById], references: [id], onDelete: SetNull)
  referredUsers    User[]             @relation("PartnerReferral")
  partnerEarnings  PartnerEarning[]
  earningsAsReferral PartnerEarning[]  @relation("EarningReferral")
  withdrawals      PartnerWithdrawal[]
  passwordResetTokens PasswordResetToken[]
}

model Establishment {
  id          String    @id @default(cuid())
  name        String
  description String?
  address     String?
  phone       String?
  logoUrl     String?
  coverUrl    String?

  yandexMapsUrl  String?
  twoGisUrl      String?
  avitoUrl       String?

  platformRotation Boolean   @default(false)
  webhookUrl       String?
  vkChatId         String?

  watermarkEnabled Boolean  @default(true)
  tipsEnabled      Boolean  @default(false)
  tipsProvider     String?
  tipsClientId     String?

  notificationEmail           String?
  notificationEmailEnabled    Boolean  @default(false)
  notificationTelegramChatId  String?
  notificationTelegramEnabled Boolean  @default(false)
  notificationMaxUserId       String?
  notificationMaxEnabled      Boolean  @default(false)

  reviewRouting Json?

  menuId         String?       @unique
  menu           QRMenu?       @relation(fields: [menuId], references: [id], onDelete: SetNull)
  businessCardId String?       @unique
  businessCard   BusinessCard? @relation(fields: [businessCardId], references: [id], onDelete: SetNull)
  wifiConfigId   String?       @unique
  wifiConfig     WifiConfig?   @relation(fields: [wifiConfigId], references: [id], onDelete: SetNull)
  pageModules    Json?
  moduleOrder    Json?
  moduleLabels   Json?
  moduleIcons    Json?
  moduleTypes    Json?
  landingTheme    String?
  brandColor      String   @default("#4f46e5")
  pageAppearance  String   @default("light")
  landingSubtitle String?
  shortSlug       String?  @unique

  legalName       String?
  inn             String?
  landingTipsType  String?
  landingTipsPhone String?
  landingTipsBankName String?
  landingTipsUrl   String?
  workingHours    Json?

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrcodes    QRCode[]
  reviews    Review[]
  promocodes PromoCode[]
  customPages CustomPage[]
  activationBatches ActivationBatch[]
  forms        Form[]
  orders       MenuOrder[]
  tipsEmployees TipsEmployee[]
  members      EstablishmentMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QRCode {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String?
  isActive      Boolean  @default(false)
  mode          QRCodeMode @default(REVIEW)
  redirectUrl   String?

  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  establishmentId String?
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: SetNull)

  templateId          String?
  template            Template?     @relation("QRTableTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  qrStyleTemplateId   String?
  qrStyleTemplate     Template?     @relation("QRStyleTemplate", fields: [qrStyleTemplateId], references: [id], onDelete: SetNull)

  businessCardId  String?
  businessCard    BusinessCard? @relation(fields: [businessCardId], references: [id], onDelete: SetNull)

  wifiConfigId    String?
  wifiConfig      WifiConfig?   @relation(fields: [wifiConfigId], references: [id], onDelete: SetNull)

  fileAssetId     String?
  fileAsset       FileAsset?    @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  menuId          String?
  menu            QRMenu?       @relation(fields: [menuId], references: [id], onDelete: SetNull)

  customSectionId String?
  customPage      CustomPage? @relation(fields: [customSectionId], references: [id], onDelete: SetNull)

  formId          String?
  form            Form?        @relation(fields: [formId], references: [id], onDelete: SetNull)

  tipsType        String?
  tipsPhone       String?
  tipsBankName    String?

  centerText    String?
  centerLogoUrl String?

  batchId    String?
  batch      ActivationBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  serialCode String?
  source     QRCodeSource     @default(DASHBOARD)

  scansCount Int      @default(0)
  reviews    Review[]
  scanLogs   QRScan[]
  tipsEmployees TipsEmployee[]
  orders     MenuOrder[]
  submissions FormSubmission[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QRScan {
  id              String   @id @default(cuid())
  qrCodeId        String
  qrCode          QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  establishmentId String?
  ip              String?
  region          String?
  browser         String?
  device          String?
  createdAt       DateTime @default(now())

  @@index([qrCodeId, createdAt])
  @@index([establishmentId, createdAt])
}

model Review {
  id              String   @id @default(cuid())
  rating          Int
  comment         String?
  guestName       String?
  guestPhone      String?
  isNegative      Boolean
  isProcessed     Boolean  @default(false)

  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  qrCodeId String?
  qrCode   QRCode?  @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  pdConsentAt DateTime?
  pdConsentIp String?

  createdAt DateTime @default(now())
}

model ActivationBatch {
  id              String      @id @default(cuid())
  masterCode      String      @unique
  status          BatchStatus @default(PENDING)
  label           String?
  qty             Int
  activatedAt     DateTime?
  createdAt       DateTime    @default(now())

  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  establishmentId String?
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: SetNull)

  qrcodes         QRCode[]
}

model Subscription {
  id              String          @id @default(cuid())
  status          SubStatus       @default(ACTIVE)
  plan            Plan            @default(FREE)
  yookassaPaymentId String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean      @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String
  discount  String
  isActive  Boolean  @default(true)
  maxUses   Int?
  usedCount Int      @default(0)

  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  OWNER
  ADMIN
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Plan {
  FREE
  PRO
  NETWORK
}

enum QRCodeMode {
  REVIEW
  REDIRECT
  BUSINESS_CARD
  WIFI
  FILE
  MENU
  LANDING
  CUSTOM_SECTION
  FORM
  TIPS
}

enum QRCodeSource {
  DASHBOARD
  MARKETPLACE
}

enum BatchStatus {
  PENDING
  ACTIVATED
}

model BusinessCard {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  title       String?
  company     String?
  phone       String?
  email       String?
  website     String?
  address     String?
  about       String?
  avatarUrl   String?
  socialLinks Json     @default("[]")
  theme       String   @default("minimal")
  accentColor String   @default("#4f46e5")

  contactEnabled       Boolean @default(false)
  contactMessengerId   String?
  contactMessenger     MessengerContact? @relation(fields: [contactMessengerId], references: [id], onDelete: SetNull)

  estId       String?
  tipsLabel   String?
  tipsUrl     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  qrcodes        QRCode[]
  establishment  Establishment?
}

enum MessengerProvider {
  TELEGRAM
  MAX
  EMAIL
}

model MessengerContact {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   MessengerProvider
  externalId String
  label      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  businessCards BusinessCard[]

  @@unique([userId, provider, externalId])
}

model WifiConfig {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ssid       String
  password   String?
  encryption String   @default("WPA")
  hidden     Boolean  @default(false)
  estId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  qrcodes        QRCode[]
  establishment  Establishment?
}

model FileAsset {
  id        String   @id @default(cuid())
  title     String?
  fileName  String
  fileUrl   String
  fileKey   String
  mimeType  String
  fileSize  Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrcodes QRCode[]
  customPages CustomPage[]
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  width       Float    @default(210)
  height      Float    @default(148)
  layout      Json
  isPublic    Boolean  @default(false)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrcodesTable   QRCode[] @relation("QRTableTemplate")
  qrcodesQrStyle QRCode[] @relation("QRStyleTemplate")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MenuSource {
  MANUAL
  IIKO
}

model QRMenu {
  id          String     @id @default(cuid())
  title       String?
  description String?
  estId       String?
  source      MenuSource @default(MANUAL)
  cartEnabled Boolean    @default(false)
  askPhone    Boolean    @default(false)
  askEmail    Boolean    @default(false)
  askAddress  Boolean    @default(false)

  iikoApiLogin            String?
  iikoOrganizationId      String?
  iikoExternalMenuId      String?
  iikoPriceCategoryId     String?
  iikoTerminalGroupId     String?
  iikoPaymentTypeId       String?
  iikoOrderTypePickupId   String?
  iikoOrderTypeDeliveryId String?
  /** id категорий iiko, скрытых в QR-меню (blacklist) */
  iikoHiddenCategoryIds   Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items          QRMenuItem[]
  qrcodes        QRCode[]
  establishment  Establishment?
}

model QRMenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       String?
  weight      String?
  category    String?
  imageUrl    String?
  order       Int      @default(0)
  hidden      Boolean  @default(false)

  menuId      String
  menu        QRMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PartnerEarning {
  id            String   @id @default(cuid())
  amount        Float
  paymentAmount Float
  status        PartnerEarningStatus @default(PENDING)
  availableAt   DateTime
  paymentId     String?
  description   String?

  partnerId     String
  partner       User     @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  referralUserId String
  referralUser   User    @relation("EarningReferral", fields: [referralUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartnerWithdrawal {
  id          String                @id @default(cuid())
  amount      Float
  status      PartnerWithdrawalStatus @default(PENDING)
  recepientName    String
  recepientInn     String
  recepientType    String
  bankName         String?
  bankBik          String?
  bankAccount      String?
  corrAccount      String?
  comment          String?
  adminComment     String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PartnerEarningStatus {
  PENDING
  AVAILABLE
  WITHDRAWN
}

enum PartnerWithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model CustomPage {
  id             String   @id @default(cuid())
  establishmentId String
  establishment  Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  menuItemLabel  String
  title          String
  content        String   @default("")
  type           String   @default("HTML")
  url            String?
  icon           String?
  enabled        Boolean  @default(true)
  fileAssetId    String?
  fileAsset      FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  qrcodes QRCode[]
}

enum MenuOrderStatus {
  NEW
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum SupportMessageAuthor {
  USER
  STAFF
}

enum EstablishmentMemberStatus {
  PENDING
  ACTIVE
}

model Form {
  id              String   @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  submitLabel     String   @default("Отправить")
  successMessage  String   @default("Спасибо! Мы получили вашу заявку и скоро свяжемся с вами.")
  preset          String?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fields      FormField[]
  submissions FormSubmission[]
  qrcodes     QRCode[]
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  label       String
  placeholder String?
  helpText    String?
  type        String   @default("text")
  required    Boolean  @default(false)
  options     Json?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  qrCodeId    String?
  qrCode      QRCode?  @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  values      Json
  guestIp     String?
  userAgent   String?
  isRead      Boolean  @default(false)
  pdConsentAt DateTime?
  pdConsentIp String?
  createdAt   DateTime @default(now())
}

model MenuOrder {
  id              String          @id @default(cuid())
  establishmentId String
  establishment   Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  qrCodeId        String?
  qrCode          QRCode?         @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  items           Json
  total           Float?
  totalText       String?
  guestName       String
  tableNumber     String?
  guestPhone      String?
  guestEmail      String?
  guestAddress    String?
  comment         String?
  guestIp         String?
  guestRegion     String?
  guestBrowser    String?
  guestDevice     String?
  status            MenuOrderStatus @default(NEW)
  iikoOrderId       String?
  iikoCorrelationId String?
  pdConsentAt       DateTime?
  pdConsentIp       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model TipsEmployee {
  id              String   @id @default(cuid())
  qrCodeId        String?
  qrCode          QRCode?  @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  photoUrl        String?
  paymentType     String   @default("PHONE")
  paymentUrl      String?
  phone           String?
  bankName        String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
}

model SupportTicket {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          SupportTicketStatus @default(OPEN)
  telegramTopicId Int?
  subject         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages SupportMessage[]
}

model SupportMessage {
  id             String                @id @default(cuid())
  ticketId       String
  ticket         SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author         SupportMessageAuthor
  body           String
  readByUser     Boolean               @default(false)
  attachmentUrl  String?
  attachmentName String?
  attachmentMime String?
  createdAt      DateTime              @default(now())
}

model EstablishmentMember {
  id              String   @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  email           String
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          EstablishmentMemberStatus @default(PENDING)
  inviteToken     String?  @unique
  invitedById     String
  invitedBy       User     @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  acceptedAt      DateTime?

  @@unique([establishmentId, email])
}

